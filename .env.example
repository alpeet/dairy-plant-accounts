# ============================================================
# Godhuli Dairy Plant — Environment Configuration
# ============================================================
# Copy this file to .env and customize as needed.
#   cp .env.example .env
#
# The app works with default values if .env is not present.
# ============================================================

# ── Server ──
# Port for the web server (default: 3000)
PORT=3000

# Host to bind to (default: 0.0.0.0 — all interfaces)
# Set to 127.0.0.1 for local-only access
HOST=0.0.0.0

# ── Authentication ──
# Default credentials used if .env is not configured:
#   Username: admin
#   Password: admin123
#
# CHANGE THESE IN PRODUCTION:
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123

# ── Database ──
# Database file location (relative to project root)
# Default: ./data/dairy-plant.db
DB_PATH=./data

# Database filename
DB_NAME=dairy-plant.db

# ── Application ──
# Application name (used in page titles, headers)
APP_NAME=Godhuli Dairy Plant

# Node environment (development / production)
NODE_ENV=development

# ── Security ──
# Web authentication uses in-memory tokens with 24-hour expiry.
# Tokens are lost on server restart. Users must re-login.
# For additional security, use a reverse proxy for HTTPS.
