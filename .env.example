# Godhuli Dairy Plant — Environment Configuration
# ================================================
# Copy this file to .env and customize as needed.
#   cp .env.example .env
#
# The app works with default values if .env is not present.
# ================================================

# ── Server ──
# Port to listen on (default: 3000)
PORT=3000

# Host to bind to (default: 0.0.0.0 — all interfaces)
# Set to 127.0.0.1 for local-only access
HOST=0.0.0.0

# ── Authentication ──
# Default admin username (default: admin)
AUTH_USERNAME=admin

# ⚠️  IMPORTANT: Set a strong password in production!
# Default: admin123 (used only when AUTH_PASSWORD env var is not set)
# For Render: set this in Dashboard → Environment (never in blueprint)
AUTH_PASSWORD=admin123

# ── Database ──
# Directory to store the SQLite database file (default: ./data)
# On Render: set to the persistent disk mount path
DB_DIR=./data

# ── Application ──
# Node environment (development / production)
NODE_ENV=development
